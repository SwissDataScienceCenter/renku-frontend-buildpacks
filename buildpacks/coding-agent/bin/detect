#!/usr/bin/env bash
unalias -a
set -euCo pipefail

plan_path="${CNB_BUILD_PLAN_PATH}"

if [[ -n "${BP_RENKU_AI_AGENTS:-}" ]]; then
  echo "PASS: BP_RENKU_AI_AGENTS=${BP_RENKU_AI_AGENTS}"
elif [[ -f "project.toml" ]]; then
  BP_RENKU_AI_AGENTS=$(awk 'BEGIN { is_set = 0; has_value=0 }
    /^\[\[io\.buildpacks\.build\.env\]\]/ {
        is_set=0
        has_value=0
    }
    /^[[:space:]]*name[[:space:]]*=[[:space:]]*"BP_RENKU_AI_AGENTS"[[:space:]]*$/ {
        is_set=1
    }
    /^[[:space:]]*value[[:space:]]*=/ {
        match($0, /"([^"]*)"/)
        value=substr($0, RSTART+1, RLENGTH-2)
        has_value=1
    }
    is_set==1 && has_value==1 {
        print value
        exit
    }' project.toml)
fi

if [[ -z "${BP_RENKU_AI_AGENTS:-}" ]]; then
  echo "SKIPPED: BP_RENKU_AI_AGENTS not set"
  exit 100
fi

cat -- >>"${plan_path}" <<EOL
[[provides]]
name = "coding-agent"

[[requires]]
name = "coding-agent"
  [requires.metadata]
    launch = true

[[requires]]
  name = "node" # provided by "paketo-buildpacks/node-engine" (https://github.com/paketo-buildpacks/node-engine)

  ## The version of the Node Engine dependency is not required. In the case it
  ## is not specified, the buildpack will provide the default version, which can
  ## be seen in the buildpack.toml file.
  ## If you wish to request a specific version, the buildpack supports
  ## specifying a semver constraint in the form of "15.*", "15.14.*", or even
  ## "15.14.0".
  # version = "15.14.0"
  [requires.metadata]
    build = true
    launch = true
EOL
