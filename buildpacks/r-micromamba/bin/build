#!/usr/bin/env bash
set -euo pipefail

LAYERS_DIR="${1}"

log() { echo "-----> $*"; }
info() { echo "       $*"; }

read_meta() {
  grep -Po "(?<=^${2} = \")([^\"]+)" "${1}" 2>/dev/null || true
}

R_VERSION="$(jq -r ".R.Version" "renv.lock" || '')"

# Default to "latest" if MICROMAMBA_VERSION is not provided.
MICROMAMBA_VERSION="${MICROMAMBA_VERSION:-latest}"

log "R Buildpack"
info "R version         : ${R_VERSION}"
info "micromamba version: ${MICROMAMBA_VERSION}"

# micromamba layer

MAMBA_LAYER="${LAYERS_DIR}/micromamba"
mkdir -p "${MAMBA_LAYER}/bin"

CACHED_MAMBA_VERSION="$(read_meta "${MAMBA_LAYER}.toml" "micromamba_version")"

case "$(uname -m)" in
x86_64) MAMBA_PLATFORM="linux-64" ;;
aarch64) MAMBA_PLATFORM="linux-aarch64" ;;
*)
  echo "ERROR: Unsupported architecture: $(uname -m)" >&2
  exit 1
  ;;
esac

CACHE_MAMBA="true"
if [[ "$MICROMAMBA_VERSION" == "latest" ]]; then
  CACHE_MAMBA="false"
fi

cat >"${MAMBA_LAYER}.toml" <<TOML
[types]
build  = true
launch = false
cache  = $CACHE_MAMBA

[metadata]
micromamba_version = "${MICROMAMBA_VERSION}"
TOML

MAMBA="${MAMBA_LAYER}/bin/micromamba"

if [[ "${CACHED_MAMBA_VERSION}" == "${MICROMAMBA_VERSION}" && -x "${MAMBA}" ]]; then
  log "Reusing cached micromamba ${MICROMAMBA_VERSION}"
else
  log "Downloading micromamba ${MICROMAMBA_VERSION}..."

  # The micromamba release API accepts "latest" or a specific version tag.
  MAMBA_URL="https://micro.mamba.pm/api/micromamba/${MAMBA_PLATFORM}/${MICROMAMBA_VERSION}"

  curl --silent --show-error --location "${MAMBA_URL}" |
    tar -xj -C "${MAMBA_LAYER}/bin" --strip-components=1 bin/micromamba

  chmod +x "${MAMBA}"
  info "micromamba installed: $("${MAMBA}" --version)"
fi

# R layer

R_LAYER="${LAYERS_DIR}/r"
mkdir -p "${R_LAYER}"

CACHED_R_VERSION="$(read_meta "${R_LAYER}.toml" "r_version")"

cat >"${R_LAYER}.toml" <<TOML
[types]
build  = true
launch = true
cache  = true

[metadata]
r_version = "${R_VERSION}"
TOML

if [[ "${CACHED_R_VERSION}" == "${R_VERSION}" && -x "${R_LAYER}/bin/R" ]]; then
  log "Reusing cached R ${R_VERSION}"
else
  log "Installing R ${R_VERSION} via micromamba (conda-forge)..."

  # Use the micromamba layer as the conda root prefix for package downloads
  # and index caching. Packages themselves are installed into ${R_LAYER}.
  MAMBA_ROOT_PREFIX="${MAMBA_LAYER}"

  R_PACKAGE_NAME="r-base"
  if [[ -n "${R_VERSION}" ]]; then
    R_PACKAGE_NAME="r-base=${R_VERSION}"
  fi
  "${MAMBA}" create \
    --prefix "${R_LAYER}" \
    --root-prefix "${MAMBA_ROOT_PREFIX}" \
    --channel conda-forge \
    --channel nodefaults \
    --yes \
    "${R_PACKAGE_NAME}" \
    r-renv \
    openjdk \
    cairo \
    zlib \
    bzip2 \
    xz \
    hdf5 \
    libxml2 \
    libpng \
    libjpeg-turbo \
    libtiff \
    2>&1 | sed 's/^/       /'

  info "R ${R_VERSION} installed to ${R_LAYER}"
fi

# Environment — launch

ENV_LAUNCH="${R_LAYER}/env.launch"
mkdir -p "${ENV_LAUNCH}"

printf '%s' "${R_LAYER}/bin" >"${ENV_LAUNCH}/PATH.prepend"
printf ':' >"${ENV_LAUNCH}/PATH.delim"
printf '%s' "${R_LAYER}/lib" >"${ENV_LAUNCH}/LD_LIBRARY_PATH.prepend"
printf ':' >"${ENV_LAUNCH}/LD_LIBRARY_PATH.delim"
printf '%s' "${R_LAYER}" >"${ENV_LAUNCH}/R_HOME.override"
printf '%s' "${R_LAYER}/lib/R/library" >"${ENV_LAUNCH}/R_LIBS.override"

# Environment — build ────────────────────────────────────────────────────

ENV_BUILD="${R_LAYER}/env.build"
mkdir -p "${ENV_BUILD}"

printf '%s' "${R_LAYER}/bin" >"${ENV_BUILD}/PATH.prepend"
printf ':' >"${ENV_BUILD}/PATH.delim"
printf '%s' "${R_LAYER}/lib" >"${ENV_BUILD}/LD_LIBRARY_PATH.prepend"
printf ':' >"${ENV_BUILD}/LD_LIBRARY_PATH.delim"
printf '%s' "${R_LAYER}" >"${ENV_BUILD}/R_HOME.override"
printf '%s' "${R_LAYER}/lib/R/library" >"${ENV_BUILD}/R_LIBS.override"
